# AI
OPENROUTER_API_KEY=your-openrouter-key-here

# TTS (optional — app falls back to browser TTS if not set)
ELEVENLABS_API_KEY=your-elevenlabs-key-here
ELEVENLABS_VOICE_ID=your-elevenlabs-voice-id-here

# App
NEXT_PUBLIC_APP_URL=https://shabd-beta.vercel.app

# Feedback (optional — webhook relay)
FEEDBACK_WEBHOOK_URL=your-feedback-webhook-here

# Firebase (get from Firebase Console → Project Settings → Service Accounts → Generate new private key)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nxxxx\n-----END PRIVATE KEY-----\n"
